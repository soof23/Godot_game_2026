[connection signal="pressed" from="play/playBack" to="." method="_on_play_back_pressed"]
[connection signal="pressed" from="play/skip" to="." method="_on_skip_pressed"]
[connection signal="pressed" from="sound/VBoxContainer/VBoxContainer/mute" to="." method="_on_mute_pressed"]
[connection signal="pressed" from="sound/VBoxContainer/VBoxContainer/unmute" to="." method="_on_unmute_pressed"]
[connection signal="value_changed" from="sound/VBoxContainer/VBoxContainer/music/audiocontrol" to="sound/VBoxContainer/VBoxContainer/music/audiocontrol" method="_on_value_changed"]
