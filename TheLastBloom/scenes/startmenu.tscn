autoplay = true
bus = &"Music"
parameters/looping = true

[node name="typewriter" type="AudioStreamPlayer2D" parent="." unique_id=742271673]
stream = ExtResource("19_ow8gm")
max_polyphony = 8
bus = &"typewriter"

